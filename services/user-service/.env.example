# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────────────────────────
# Docker: postgresql://walletos:<password>@postgres:5432/walletos_users
# Local:  postgresql://walletos:<password>@localhost:5432/walletos_users
DATABASE_URL=postgresql://walletos:secret@localhost:5432/walletos_users

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://walletos:secret@localhost:5672

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
INTERNAL_SECRET=

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Apple Sign In ───────────────────────────────────────────────────────────
APPLE_TEAM_ID=
APPLE_SIGN_IN_KEY_ID=
APPLE_SIGN_IN_CLIENT_ID=com.walletOS.app

# ─── Google Sign In ──────────────────────────────────────────────────────────
GOOGLE_IOS_CLIENT_ID=
