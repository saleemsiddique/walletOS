# WalletOS — Master secrets reference
# Copia este archivo como .env.master y rellena los valores reales.
# NUNCA commitear .env.master — está en .gitignore.
# Los valores finales van a GitHub Actions Secrets para el deploy a producción.

# ─── Apple Developer ────────────────────────────────────────────────────────

# Sign in with Apple
APPLE_TEAM_ID=                        # 10 chars, ej: AB12CD34EF
APPLE_SIGN_IN_KEY_ID=                 # 10 chars, ej: XY98ZW76VU
APPLE_SIGN_IN_CLIENT_ID=com.walletOS.app
# Archivo .p8 → guardado en Keychain de macOS como "WalletOS Apple Sign In Key"
# Path local (solo referencia): ~/keys/AuthKey_<SIGN_IN_KEY_ID>.p8

# APNs (Push Notifications)
APNS_KEY_ID=                          # 10 chars, distinto al de Sign In
APNS_TEAM_ID=                         # mismo que APPLE_TEAM_ID
APNS_BUNDLE_ID=com.walletOS.app
# Archivo .p8 → guardado en Keychain de macOS como "WalletOS APNs Key"
# Path local (solo referencia): ~/keys/AuthKey_<APNS_KEY_ID>.p8

# ─── Google Cloud ───────────────────────────────────────────────────────────

GOOGLE_CLOUD_PROJECT_ID=              # ej: walletos-prod-123456
GOOGLE_IOS_CLIENT_ID=                 # ej: 123456789-abc.apps.googleusercontent.com
# GOOGLE_WEB_CLIENT_ID=              # opcional — solo si el backend verifica id_tokens

# ─── OpenAI ─────────────────────────────────────────────────────────────────

OPENAI_API_KEY=                       # sk-...

# ─── Resend ─────────────────────────────────────────────────────────────────

RESEND_API_KEY=                       # re_...

# ─── AWS ────────────────────────────────────────────────────────────────────

AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=                    # IAM user walletos-dev
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_DEV=walletos-exports-dev
AWS_S3_BUCKET_PROD=walletos-exports-prod
